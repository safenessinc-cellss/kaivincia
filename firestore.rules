rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "safeness.c.a@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "superadmin"]
      );
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules (todas las reglas específicas aquí)
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isUser(userId) || isAdmin());
      allow update: if isAuthenticated() && (isUser(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /client_interactions/{interactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    match /chat_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /candidates/{candidateId} {
      allow read: if isAuthenticated();
      allow create: if true; // Public form
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if true; // Publicly visible job board
      allow write: if isAdmin();
    }

    match /b2b_entities/{entityId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /subscriptions/{subId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /academic_progress/{progressId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Logs are immutable
    }

    match /security_alerts/{alertId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /automation_rules/{ruleId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /automation_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /collaborators/{collaboratorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /prospects/{prospectId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidProject(incoming());
      allow update: if isAuthenticated() && isValidProject(incoming());
      allow delete: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidInvoice(incoming());
      allow update: if isAdmin() && isValidInvoice(incoming());
      allow delete: if isAdmin();
    }

    match /time_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTimeLog(incoming());
      allow update: if isAuthenticated() && (isAdmin() || (existing().userUid == request.auth.uid && isValidTimeLog(incoming())));
      allow delete: if isAdmin();
    }

    match /automation_workflows/{workflowId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /system_events/{eventId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /attendance_logs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /absence_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /documents/{documentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // ===============================================================
    // Global Safety Net (DEBE ir al FINAL)
    // ===============================================================
    match /{document=**} { 
      allow read, write: if false; 
    }
    
    // ===============================================================
    // Validation Helpers
    // ===============================================================

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidProject(data) {
      return data.clientId is string &&
             data.name is string && data.name.size() > 0 &&
             data.status in ['Planificación', 'En ejecución', 'En riesgo', 'Finalizado'];
    }

    function isValidInvoice(data) {
      return data.clientId is string &&
             data.amount is number &&
             data.status in ['Pendiente', 'Pagada', 'Vencida', 'Cancelada'];
    }

    function isValidTimeLog(data) {
      return data.projectId is string &&
             data.hours is number &&
             data.userUid == request.auth.uid;
    }
  }
}
