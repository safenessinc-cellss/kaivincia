{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin", "superadmin"],
          "description": "The user's role."
        },
        "status": {
          "type": "string",
          "enum": ["active", "pending", "inactive", "suspended"],
          "description": "The user's account status."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's avatar image."
        },
        "lastLoginIp": {
          "type": "string",
          "description": "The IP address of the user's last login."
        },
        "lastLoginCountry": {
          "type": "string",
          "description": "The country of the user's last login."
        },
        "twoFactorEnabled": {
          "type": "boolean",
          "description": "Whether 2FA is enabled for the user."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the user was created."
        }
      },
      "required": ["uid", "name", "email", "role", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Records system activity for security and compliance.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who performed the action."
        },
        "userEmail": {
          "type": "string",
          "description": "The email of the user who performed the action."
        },
        "action": {
          "type": "string",
          "description": "The action performed (e.g., 'UPDATE_CLIENT_STATUS')."
        },
        "resourceType": {
          "type": "string",
          "description": "The type of resource affected (e.g., 'Client', 'User')."
        },
        "resourceId": {
          "type": "string",
          "description": "The ID of the resource affected."
        },
        "details": {
          "type": "string",
          "description": "JSON string containing previous and new values."
        },
        "ipAddress": {
          "type": "string",
          "description": "The IP address from which the action was performed."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the action occurred."
        }
      },
      "required": ["userId", "action", "resourceType", "timestamp"]
    },
    "SecurityAlert": {
      "title": "Security Alert",
      "description": "Alerts generated by the system for suspicious activity.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user involved."
        },
        "type": {
          "type": "string",
          "enum": ["DATA_EXPORT_LIMIT_EXCEEDED", "UNUSUAL_LOGIN_LOCATION", "MULTIPLE_FAILED_LOGINS"],
          "description": "The type of alert."
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "The severity of the alert."
        },
        "details": {
          "type": "string",
          "description": "Description of the alert."
        },
        "status": {
          "type": "string",
          "enum": ["open", "resolved"],
          "description": "Whether the alert has been addressed."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the alert was generated."
        }
      },
      "required": ["type", "severity", "status", "timestamp"]
    },
    "AutomationRule": {
      "title": "Automation Rule",
      "description": "Defines an IF-THEN automation workflow.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "triggerType": {
          "type": "string",
          "enum": ["COURSE_COMPLETED", "HEALTH_SCORE_DROP", "NEW_CLIENT_REGISTERED"]
        },
        "triggerConditions": {
          "type": "string",
          "description": "JSON string containing specific conditions (e.g., score < 40)"
        },
        "actionType": {
          "type": "string",
          "enum": ["SEND_PUSH_NOTIFICATION", "CREATE_URGENT_TASK", "ACTIVATE_ONBOARDING", "SEND_WEBHOOK"]
        },
        "actionPayload": {
          "type": "string",
          "description": "JSON string containing action details (e.g., message, webhook URL)"
        },
        "isActive": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "triggerType", "actionType", "isActive"]
    },
    "AutomationLog": {
      "title": "Automation Log",
      "description": "Records executions of automation rules.",
      "type": "object",
      "properties": {
        "ruleId": {
          "type": "string"
        },
        "ruleName": {
          "type": "string"
        },
        "targetId": {
          "type": "string",
          "description": "ID of the user, client, or student affected."
        },
        "status": {
          "type": "string",
          "enum": ["success", "failed"]
        },
        "details": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["ruleId", "status", "timestamp"]
    },
    "Client": {
      "title": "Client",
      "description": "Represents a B2B client or Agency partner.",
      "type": "object",
      "properties": {
        "companyName": {
          "type": "string"
        },
        "contactName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["Lead", "Activo", "En Riesgo", "Pausado", "Finalizado"]
        },
        "paymentModel": {
          "type": "string",
          "enum": ["Fijo", "Híbrido", "Variable"]
        },
        "contractValue": {
          "type": "number"
        },
        "healthScore": {
          "type": "number"
        },
        "assignedManagerId": {
          "type": "string",
          "description": "UID of the specialist managing this account."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["companyName", "status", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "Represents an operational project for a client.",
      "type": "object",
      "properties": {
        "clientId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["Planificación", "En ejecución", "En riesgo", "Finalizado"]
        },
        "progress": {
          "type": "number"
        },
        "startDate": {
          "type": "string",
          "format": "date"
        },
        "endDate": {
          "type": "string",
          "format": "date"
        },
        "budget": {
          "type": "number"
        }
      },
      "required": ["clientId", "name", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Represents a financial transaction or bill.",
      "type": "object",
      "properties": {
        "clientId": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string",
          "enum": ["USD", "BRL"]
        },
        "status": {
          "type": "string",
          "enum": ["Pendiente", "Pagada", "Vencida", "Cancelada"]
        },
        "dueDate": {
          "type": "string",
          "format": "date-time"
        },
        "paidAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["clientId", "amount", "status", "dueDate"]
    },
    "Task": {
      "title": "Task",
      "description": "Represents a task in the CRM.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the task."
        },
        "description": {
          "type": "string",
          "description": "The description of the task."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in-progress", "completed"],
          "description": "The status of the task."
        },
        "assignedTo": {
          "type": "string",
          "description": "The UID of the user assigned to the task."
        },
        "dueDate": {
          "type": "string",
          "format": "date-time",
          "description": "The due date of the task."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the task was created."
        }
      },
      "required": ["title", "status", "createdAt"]
    },
    "Candidate": {
      "title": "Candidate",
      "description": "Represents a job applicant.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The candidate's name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The candidate's email address."
        },
        "phone": {
          "type": "string",
          "description": "The candidate's phone number."
        },
        "role": {
          "type": "string",
          "description": "The role the candidate is applying for."
        },
        "status": {
          "type": "string",
          "description": "The candidate's current stage in the recruitment process."
        },
        "aiScore": {
          "type": "number",
          "description": "AI generated score for the candidate."
        },
        "aiSummary": {
          "type": "string",
          "description": "AI generated summary of the candidate."
        },
        "aiJustification": {
          "type": "string",
          "description": "AI generated justification of the match score against the TDR."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the candidate applied."
        }
      },
      "required": ["name", "email", "role", "status", "createdAt"]
    },
    "TimeLog": {
      "title": "Time Log",
      "description": "Represents a record of hours worked on a project.",
      "type": "object",
      "properties": {
        "projectId": {
          "type": "string"
        },
        "hours": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "userName": {
          "type": "string"
        },
        "userUid": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["projectId", "hours", "date", "userUid", "createdAt"]
    },
    "ClientInteraction": {
      "title": "Client Interaction",
      "description": "Represents a chronological communication or interaction note for a client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "type": { "type": "string" },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "assignedUser": { "type": "string" }
      },
      "required": ["clientId", "type", "note", "timestamp", "assignedUser"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Represents a message in the internal chat system.",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "sender": { "type": "string" },
        "role": { "type": "string", "enum": ["team", "customer"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["channelId", "sender", "role", "text"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Represents a user's subscription to a digital product or membership.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "productName": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["Activa", "Cancelada", "Pago Fallido"]
        },
        "amount": {
          "type": "number"
        },
        "nextBillingDate": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "productName", "status"]
    },
    "AcademicProgress": {
      "title": "Academic Progress",
      "description": "Tracks a student's progress in the academy.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "courseName": {
          "type": "string"
        },
        "progressPercentage": {
          "type": "number"
        },
        "isCertified": {
          "type": "boolean"
        },
        "lastAccess": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["userId", "courseName", "progressPercentage"]
    },
    "JobPosting": {
      "title": "JobPosting",
      "description": "Represents an open job position.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the job."
        },
        "department": {
          "type": "string",
          "description": "The department the job belongs to."
        },
        "location": {
          "type": "string",
          "description": "The location of the job."
        },
        "type": {
          "type": "string",
          "description": "The type of employment (e.g., Full-time)."
        },
        "description": {
          "type": "string",
          "description": "The job description."
        },
        "isUrgent": {
          "type": "boolean",
          "description": "Whether the job is urgently hiring."
        },
        "status": {
          "type": "string",
          "enum": ["active", "closed"],
          "description": "The status of the job posting."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the job was posted."
        }
      },
      "required": ["title", "department", "location", "type", "status", "createdAt"]
    },
    "VoipProviderConfig": {
      "title": "VoipProviderConfig",
      "description": "Configuration for a VoIP provider.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the VoIP provider."
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "description": "The status of the provider."
        },
        "costPerMinute": {
          "type": "number",
          "description": "Estimated cost per minute."
        },
        "isDefault": {
          "type": "boolean",
          "description": "Whether this is the default provider."
        },
        "accountId": {
          "type": "string",
          "description": "The Account SID or ID."
        },
        "apiKey": {
          "type": "string",
          "description": "The Auth Token or API Key."
        },
        "iframeUrl": {
          "type": "string",
          "description": "The URL for the webphone iframe."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The date and time the configuration was last updated."
        }
      },
      "required": ["name", "status", "updatedAt"]
    },
    "Collaborator": {
      "title": "Collaborator",
      "description": "Represents a team member or employee.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "paymentType": { "type": "string", "enum": ["Fijo", "Hora", "Cita", "Mixto"] },
        "baseSalary": { "type": "number" },
        "ratePerUnit": { "type": "number" },
        "status": { "type": "string", "enum": ["Activo", "Inactivo"] },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "paymentType", "status", "email", "createdAt"]
    },
    "Prospect": {
      "title": "Prospect",
      "description": "Represents a potential client or lead in the global database.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "distributor": { "type": "string" },
        "project": { "type": "string" },
        "status": { "type": "string", "enum": ["Nuevo", "Contactado", "Convertido"] },
        "lastContact": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "User"
      },
      "description": "Stores user profiles."
    },
    "/clients/{clientId}": {
      "schema": {
        "$ref": "Client"
      },
      "description": "Stores client records."
    },
    "/projects/{projectId}": {
      "schema": {
        "$ref": "Project"
      },
      "description": "Stores operational projects."
    },
    "/invoices/{invoiceId}": {
      "schema": {
        "$ref": "Invoice"
      },
      "description": "Stores financial transactions."
    },
    "/tasks/{taskId}": {
      "schema": {
        "$ref": "Task"
      },
      "description": "Stores tasks."
    },
    "/time_logs/{logId}": {
      "schema": {
        "$ref": "TimeLog"
      },
      "description": "Stores time logs for projects."
    },
    "/candidates/{candidateId}": {
      "schema": {
        "$ref": "Candidate"
      },
      "description": "Stores job applicants."
    },
    "/jobs/{jobId}": {
      "schema": {
        "$ref": "JobPosting"
      },
      "description": "Stores job postings."
    },
    "/settings/voip_providers": {
      "schema": {
        "type": "object",
        "properties": {
          "providers": {
            "type": "array",
            "items": {
              "$ref": "VoipProviderConfig"
            }
          },
          "routingRule": {
            "type": "string"
          }
        }
      },
      "description": "Stores VoIP provider configurations."
    },
    "/audit_logs/{logId}": {
      "schema": {
        "$ref": "AuditLog"
      },
      "description": "Stores system audit logs."
    },
    "/security_alerts/{alertId}": {
      "schema": {
        "$ref": "SecurityAlert"
      },
      "description": "Stores security alerts."
    },
    "/automation_rules/{ruleId}": {
      "schema": {
        "$ref": "AutomationRule"
      },
      "description": "Stores automation workflows."
    },
    "/automation_logs/{logId}": {
      "schema": {
        "$ref": "AutomationLog"
      },
      "description": "Stores execution logs of automation rules."
    },
    "/collaborators/{collaboratorId}": {
      "schema": { "$ref": "Collaborator" },
      "description": "Stores team member records."
    },
    "/prospects/{prospectId}": {
      "schema": { "$ref": "Prospect" },
      "description": "Stores global lead database."
    },
    "/client_interactions/{interactionId}": {
      "schema": { "$ref": "ClientInteraction" },
      "description": "Chronological history of interactions with the client."
    },
    "/chat_messages/{messageId}": {
      "schema": { "$ref": "ChatMessage" },
      "description": "Internal and client chat messages."
    }
  }
}
