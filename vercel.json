{
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/images/$1",
      "headers": { "Cache-Control": "public, max-age=3600" }
    },
    {
      "src": "/(.*)\\.(jpg|jpeg|png|gif|svg|ico|webp)$",
      "dest": "/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/",
      "status": 200
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install"
}
